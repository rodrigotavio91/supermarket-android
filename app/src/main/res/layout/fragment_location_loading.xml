<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Permission Request Screen -->
    <LinearLayout
        android:id="@+id/permission_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="@dimen/spacing_large"
        android:visibility="visible">

        <TextView
            android:id="@+id/tv_permission_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/location_permission_icon"
            android:textSize="64sp"
            android:layout_marginBottom="@dimen/spacing_normal" />

        <TextView
            android:id="@+id/tv_permission_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/location_permission_title"
            android:textSize="@dimen/text_size_title"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="@dimen/spacing_small" />

        <TextView
            android:id="@+id/tv_permission_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/location_permission_message"
            android:textSize="@dimen/text_size_body"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:layout_marginBottom="@dimen/spacing_large" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_grant_permission"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/location_grant_permission" />
    </LinearLayout>

</FrameLayout>
