<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Loading State -->
    <LinearLayout
        android:id="@+id/loading_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="@dimen/spacing_large"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:indeterminateTint="@color/primary" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_normal"
            android:text="@string/location_detecting"
            android:textSize="@dimen/text_size_body"
            android:textColor="@color/text_primary"
            android:gravity="center" />
    </LinearLayout>

    <!-- Success State - Store Found -->
    <LinearLayout
        android:id="@+id/success_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="@dimen/spacing_large"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/location_success_icon"
            android:textSize="64sp"
            android:layout_marginBottom="@dimen/spacing_normal" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/location_success_title"
            android:textSize="@dimen/text_size_title"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="@dimen/spacing_small" />

        <TextView
            android:id="@+id/tv_store_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_size_subtitle"
            android:textColor="@color/primary"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="@dimen/spacing_small" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/location_success_message"
            android:textSize="@dimen/text_size_body"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:layout_marginBottom="@dimen/spacing_large" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_continue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/location_continue" />
    </LinearLayout>

    <!-- No Store Found State -->
    <LinearLayout
        android:id="@+id/no_store_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="@dimen/spacing_large"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/location_no_store_icon"
            android:textSize="64sp"
            android:layout_marginBottom="@dimen/spacing_normal" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/location_no_store_title"
            android:textSize="@dimen/text_size_title"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="@dimen/spacing_small" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/location_no_store_message"
            android:textSize="@dimen/text_size_body"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:layout_marginBottom="@dimen/spacing_large" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_continue_no_store"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/location_continue" />
    </LinearLayout>

    <!-- Permission Required State -->
    <LinearLayout
        android:id="@+id/permission_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="@dimen/spacing_large"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/location_permission_icon"
            android:textSize="64sp"
            android:layout_marginBottom="@dimen/spacing_normal" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/location_permission_title"
            android:textSize="@dimen/text_size_title"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="@dimen/spacing_small" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/location_permission_message"
            android:textSize="@dimen/text_size_body"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:layout_marginBottom="@dimen/spacing_large" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_grant_permission"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/location_continue" />
    </LinearLayout>

</FrameLayout>
